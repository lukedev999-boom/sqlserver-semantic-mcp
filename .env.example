SEMANTIC_MCP_MSSQL_SERVER=localhost
SEMANTIC_MCP_MSSQL_DATABASE=YourDatabase
SEMANTIC_MCP_MSSQL_USER=sa
SEMANTIC_MCP_MSSQL_PASSWORD=YourStrongPassword

# Optional connection settings
# SEMANTIC_MCP_MSSQL_PORT=1433
# SEMANTIC_MCP_MSSQL_WINDOWS_AUTH=false
# SEMANTIC_MCP_MSSQL_ENCRYPT=false

# Cache and startup
# SEMANTIC_MCP_CACHE_PATH=./cache/semantic_mcp.db
# SEMANTIC_MCP_CACHE_ENABLED=true
# SEMANTIC_MCP_STARTUP_MODE=cache_first
# SEMANTIC_MCP_BACKGROUND_BATCH_SIZE=5
# SEMANTIC_MCP_BACKGROUND_INTERVAL_MS=500

# Policy
# SEMANTIC_MCP_POLICY_FILE=./config/policy.example.json
# SEMANTIC_MCP_POLICY_PROFILE=readonly
# SEMANTIC_MCP_MAX_ROWS_RETURNED=1000
# SEMANTIC_MCP_MAX_ROWS_AFFECTED=100
# SEMANTIC_MCP_QUERY_TIMEOUT=30

# Tool surface
# SEMANTIC_MCP_TOOL_PROFILE=all
# SEMANTIC_MCP_WORKFLOW_TOOLS_ENABLED=true
# SEMANTIC_MCP_DIRECT_EXECUTE_ENABLED=true
# SEMANTIC_MCP_STRICT_ROWS_AFFECTED_CAP=true

# Agent-oriented defaults
# SEMANTIC_MCP_DEFAULT_DETAIL=brief
# SEMANTIC_MCP_DEFAULT_RESPONSE_MODE=summary
# SEMANTIC_MCP_DEFAULT_TOKEN_BUDGET_HINT=low

# Metrics and analysis
# SEMANTIC_MCP_METRICS_ENABLED=true
# SEMANTIC_MCP_INTENT_ANALYZER=regex
